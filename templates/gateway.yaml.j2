apiVersion: gateway.networking.k8s.io/v1
kind: Gateway
metadata:
  name: main-gateway
  namespace: istio-system
  annotations:
    # Tells MetalLB to use the same IP for TCP/UDP if needed, 
    # and ensures integration between Istio's generated Service and MetalLB
    metallb.universe.tf/allow-shared-ip: "istio-gateway"
spec:
  gatewayClassName: istio
  listeners:
  - name: http
    port: 80
    protocol: HTTP
    allowedRoutes:
      namespaces:
        from: All
  - name: https
    port: 443
    protocol: HTTPS
    allowedRoutes:
      namespaces:
        from: All
    tls:
      mode: Terminate
      certificateRefs:
      # Placeholder: You will need to create this Secret or use Cert-Manager later
      - name: default-cert
